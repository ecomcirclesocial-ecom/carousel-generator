# Secrets
.env
.env.local
*.env

# Cache (datos scrapeados, foto temporales)
cache/

# Output (carruseles generados — excepto examples/)
output/

# Fotos en assets/ (el owner usa la suya, los users la suya)
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.png
!assets/.gitkeep

# Presets personales (usuarios scrapean sus propios creadores)
presets/*.json
!presets/.gitkeep
!presets/community/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
